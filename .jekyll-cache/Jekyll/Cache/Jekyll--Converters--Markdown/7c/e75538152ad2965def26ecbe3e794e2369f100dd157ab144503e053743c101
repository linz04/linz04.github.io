  <span class="k">if</span> <span class="p">(</span><span class="nx">type</span><span class="p">.</span><span class="nx">Is</span><span class="p">(</span><span class="nx">cache_</span><span class="o">-&gt;</span><span class="nx">kZeroish</span><span class="p">))</span> <span class="k">return</span> <span class="nx">type</span><span class="p">;</span>
  <span class="nx">bool</span> <span class="nx">maybe_minuszero</span> <span class="o">=</span> <span class="nx">type</span><span class="p">.</span><span class="nx">Maybe</span><span class="p">(</span><span class="nx">Type</span><span class="p">::</span><span class="nx">MinusZero</span><span class="p">());</span>
