  <span class="nx">type</span> <span class="o">=</span> <span class="nx">Type</span><span class="p">::</span><span class="nx">Intersect</span><span class="p">(</span><span class="nx">type</span><span class="p">,</span> <span class="nx">Type</span><span class="p">::</span><span class="nx">PlainNumber</span><span class="p">(),</span> <span class="nx">zone</span><span class="p">());</span>
  <span class="k">if</span> <span class="p">(</span><span class="nx">type</span><span class="p">.</span><span class="nx">IsNone</span><span class="p">())</span> <span class="p">{</span>
