<span class="n">sc</span> <span class="o">=</span> <span class="p">[</span> <span class="n">sc</span><span class="p">[</span><span class="n">i</span><span class="p">:</span><span class="n">i</span><span class="o">+</span><span class="n">chunk_size</span><span class="p">]</span> <span class="k">for</span> <span class="n">i</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="mi">0</span><span class="p">,</span> <span class="n">chunks</span><span class="p">,</span> <span class="n">chunk_size</span><span class="p">)</span> <span class="p">]</span>
