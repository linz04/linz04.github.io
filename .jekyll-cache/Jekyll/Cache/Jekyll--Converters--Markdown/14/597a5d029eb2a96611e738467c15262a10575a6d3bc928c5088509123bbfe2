<span class="n">rwxp</span> <span class="o">=</span> <span class="n">do2hex</span><span class="p">(</span><span class="nb">float</span><span class="p">(</span><span class="n">res</span><span class="p">[</span><span class="mi">0</span><span class="p">]))</span><span class="o">-</span><span class="mh">0xe9340</span>
<span class="k">print</span><span class="p">(</span><span class="s">"rwxp: "</span><span class="p">,</span> <span class="nb">hex</span><span class="p">(</span><span class="n">rwxp</span><span class="p">))</span>
